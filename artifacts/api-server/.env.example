# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement — API Server (Railway)
# Copiez ce fichier en .env pour le développement local.
# Sur Railway, configurez ces variables dans Settings > Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données (PostgreSQL Railway) ──────────────────────────────────────
# Fournie automatiquement par Railway lorsque vous attachez un service PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Serveur ───────────────────────────────────────────────────────────────────
# Railway injecte PORT automatiquement. Ne pas modifier en production.
PORT=8080

# ── Authentification JWT ──────────────────────────────────────────────────────
# Chaîne aléatoire longue (min. 64 caractères). Générez avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=remplacez_par_une_chaine_aleatoire_tres_longue

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL(s) du frontend Vercel, séparées par des virgules.
# Ex : https://m15-audit.vercel.app,https://m15-audit.ci
CORS_ORIGIN=https://votre-app.vercel.app

# ── Emails transactionnels (Resend) ───────────────────────────────────────────
# Obtenez votre clé sur https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adresse expéditrice (doit correspondre à un domaine vérifié sur Resend).
SMTP_FROM=M15-AUDIT <noreply@votre-domaine.ci>
