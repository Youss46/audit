  "dependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.22.0",
    "tsx": "catalog:",
    "xlsx": "^0.18.5",
